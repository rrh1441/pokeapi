  "components": {
    "schemas": {
      "ActiveListingsRequest": {
        "properties": {
          "query": {
            "type": "string",
            "title": "Query",
            "description": "Search query"
          },
          "min_price": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Min Price",
            "description": "Minimum price filter"
          },
          "max_price": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Price",
            "description": "Maximum price filter"
          },
          "limit": {
            "type": "integer",
            "maximum": 200.0,
            "minimum": 1.0,
            "title": "Limit",
            "description": "Maximum results to return",
            "default": 50
          },
          "category": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Category",
            "description": "eBay category ID"
          },
          "listing_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Listing Type",
            "description": "'auction' or 'buy_it_now'"
          }
        },
        "type": "object",
        "required": [
          "query"
        ],
        "title": "ActiveListingsRequest"
      },
      "ActiveListingsResponse": {
        "properties": {
          "query": {
            "type": "string",
            "title": "Query"
          },
          "count": {
            "type": "integer",
            "title": "Count"
          },
          "listings": {
            "items": {
              "$ref": "#/components/schemas/ListingItem"
            },
            "type": "array",
            "title": "Listings"
          },
          "scraped_at": {
            "type": "string",
            "title": "Scraped At"
          }
        },
        "type": "object",
        "required": [
          "query",
          "count",
          "listings",
          "scraped_at"
        ],
        "title": "ActiveListingsResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ListingItem": {
        "properties": {
          "title": {
            "type": "string",
            "title": "Title"
          },
          "price": {
            "type": "number",
            "title": "Price"
          },
          "url": {
            "type": "string",
            "title": "Url"
