            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ebay Item Id"
          },
          "sold_date": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Sold Date"
          },
          "bids": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bids"
          },
          "time_left": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
