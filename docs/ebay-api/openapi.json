          },
          "avg_price": {
            "type": "number",
            "title": "Avg Price"
          },
          "min_price": {
            "type": "number",
            "title": "Min Price"
          },
          "max_price": {
            "type": "number",
            "title": "Max Price"
          },
          "count": {
            "type": "integer",
            "title": "Count"
          }
        },
        "type": "object",
        "required": [
          "median_price",
          "avg_price",
          "min_price",
          "max_price",
          "count"
        ],
        "title": "PriceStats"
      },
      "SoldListingsRequest": {
        "properties": {
          "query": {
            "type": "string",
            "title": "Query",
            "description": "Search query",
            "example": "PSA 10 Charizard"
          },
          "min_price": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Min Price",
            "description": "Minimum price filter"
          },
          "max_price": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Price",
            "description": "Maximum price filter"
          },
          "limit": {
            "type": "integer",
            "maximum": 200.0,
            "minimum": 1.0,
            "title": "Limit",
            "description": "Maximum results to return",
            "default": 50
          },
          "category": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Category",
            "description": "eBay category ID"
          }
        },
        "type": "object",
        "required": [
          "query"
        ],
        "title": "SoldListingsRequest"
      },
      "SoldListingsResponse": {
        "properties": {
          "query": {
            "type": "string",
            "title": "Query"
          },
          "count": {
            "type": "integer",
            "title": "Count"
          },
          "listings": {
            "items": {
              "$ref": "#/components/schemas/ListingItem"
            },
            "type": "array",
            "title": "Listings"
          },
          "stats": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PriceStats"
