# Proxy Configuration (DataImpulse, Bright Data, etc.)
PROXY_ENABLED=true
PROXY_HOST=gw.dataimpulse.com
PROXY_PORT=823
PROXY_USERNAME=your_username
PROXY_PASSWORD=your_password

# eBay API Credentials (optional, for Browse API client)
EBAY_CLIENT_ID=your_client_id
EBAY_CLIENT_SECRET=your_client_secret

# API Authentication
# Comma-separated list of valid API keys for direct access
API_KEYS=your_api_key_1,your_api_key_2

# RapidAPI Integration
# Set this to the proxy secret from RapidAPI dashboard
RAPIDAPI_PROXY_SECRET=your_rapidapi_secret
